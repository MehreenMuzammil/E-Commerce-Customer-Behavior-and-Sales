      <column caption='RFM Segment' datatype='string' name='[Calculation_1756614990076665867]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Calculation_1756614989522669571] &gt;= 4&#10;AND [Calculation_1756614990065725445] &gt;= 4&#10;AND [Calculation_1756614990065926150] &gt;= 4 THEN &quot;Champions&quot;&#10;&#10;ELSEIF [Calculation_1756614989522669571] &lt;= 2&#10;AND [Calculation_1756614990065725445] &gt;= 4&#10;AND [Calculation_1756614990065926150] &gt;= 3 THEN &quot;At Risk – High Value&quot;&#10;&#10;ELSEIF [Calculation_1756614989522669571] &gt;= 4&#10;AND [Calculation_1756614990065725445] &lt;= 2 THEN &quot;New / Promising Customers&quot;&#10;&#10;ELSEIF [Calculation_1756614989522669571] &lt;= 2&#10;AND [Calculation_1756614990065725445] &lt;= 2 THEN &quot;Lost Customers&quot;&#10;&#10;ELSE &quot;Potential Loyalists&quot;&#10;END' />
