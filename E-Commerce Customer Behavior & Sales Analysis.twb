      <column caption='Recency Score' datatype='integer' name='[Calculation_1756614989522669571]' role='dimension' type='ordinal'>
        <calculation class='tableau' formula='IF [Calculation_1756614989515198464] &lt;= &#10;    { FIXED : PERCENTILE([Calculation_1756614989515198464], 0.2) } THEN 5&#10;ELSEIF [Calculation_1756614989515198464] &lt;= &#10;    { FIXED : PERCENTILE([Calculation_1756614989515198464], 0.4) } THEN 4&#10;ELSEIF [Calculation_1756614989515198464] &lt;= &#10;    { FIXED : PERCENTILE([Calculation_1756614989515198464], 0.6) } THEN 3&#10;ELSEIF [Calculation_1756614989515198464] &lt;= &#10;    { FIXED : PERCENTILE([Calculation_1756614989515198464], 0.8) } THEN 2&#10;ELSE 1&#10;END' />
