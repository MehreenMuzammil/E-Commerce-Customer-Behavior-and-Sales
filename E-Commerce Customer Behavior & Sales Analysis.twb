      <column caption='Frequency Score' datatype='integer' name='[Calculation_1756614990065725445]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [total_orders] &gt;= &#10;    { FIXED : PERCENTILE([total_orders], 0.8) } THEN 5&#10;ELSEIF [total_orders] &gt;= &#10;    { FIXED : PERCENTILE([total_orders], 0.6) } THEN 4&#10;ELSEIF [total_orders] &gt;= &#10;    { FIXED : PERCENTILE([total_orders], 0.4) } THEN 3&#10;ELSEIF [total_orders] &gt;= &#10;    { FIXED : PERCENTILE([total_orders], 0.2) } THEN 2&#10;ELSE 1&#10;END' />
      </column>
      <column caption='Monetary Score' datatype='integer' name='[Calculation_1756614990065926150]' role='measure' type='quantitative'>
