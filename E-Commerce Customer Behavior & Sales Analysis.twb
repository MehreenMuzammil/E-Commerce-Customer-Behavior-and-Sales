    <worksheet name='Customer Distribution by RFM Segment'>
      <table>
        <view>
          <datasources>
            <datasource caption='cleaned_transaction_data.csv+ (Multiple Connections)' name='federated.1lfs3r41pqgmu012753eo1esbdjw' />
          </datasources>
          <datasource-dependencies datasource='federated.1lfs3r41pqgmu012753eo1esbdjw'>
            <column caption='Recency' datatype='integer' name='[Calculation_1756614989515198464]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='DATEDIFF(&#10;    &apos;day&apos;,&#10;    { FIXED [customer_id] : MAX([last_purchase_date]) },&#10;    TODAY()&#10;)' />
            </column>
            <column caption='Recency Score' datatype='integer' name='[Calculation_1756614989522669571]' role='dimension' type='ordinal'>
              <calculation class='tableau' formula='IF [Calculation_1756614989515198464] &lt;= &#10;    { FIXED : PERCENTILE([Calculation_1756614989515198464], 0.2) } THEN 5&#10;ELSEIF [Calculation_1756614989515198464] &lt;= &#10;    { FIXED : PERCENTILE([Calculation_1756614989515198464], 0.4) } THEN 4&#10;ELSEIF [Calculation_1756614989515198464] &lt;= &#10;    { FIXED : PERCENTILE([Calculation_1756614989515198464], 0.6) } THEN 3&#10;ELSEIF [Calculation_1756614989515198464] &lt;= &#10;    { FIXED : PERCENTILE([Calculation_1756614989515198464], 0.8) } THEN 2&#10;ELSE 1&#10;END' />
            </column>
            <column caption='Frequency Score' datatype='integer' name='[Calculation_1756614990065725445]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IF [total_orders] &gt;= &#10;    { FIXED : PERCENTILE([total_orders], 0.8) } THEN 5&#10;ELSEIF [total_orders] &gt;= &#10;    { FIXED : PERCENTILE([total_orders], 0.6) } THEN 4&#10;ELSEIF [total_orders] &gt;= &#10;    { FIXED : PERCENTILE([total_orders], 0.4) } THEN 3&#10;ELSEIF [total_orders] &gt;= &#10;    { FIXED : PERCENTILE([total_orders], 0.2) } THEN 2&#10;ELSE 1&#10;END' />
            </column>
            <column caption='Monetary Score' datatype='integer' name='[Calculation_1756614990065926150]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IF [total_spend] &gt;= &#10;    { FIXED : PERCENTILE([total_spend], 0.8) } THEN 5&#10;ELSEIF [total_spend] &gt;= &#10;    { FIXED : PERCENTILE([total_spend], 0.6) } THEN 4&#10;ELSEIF [total_spend] &gt;= &#10;    { FIXED : PERCENTILE([total_spend], 0.4) } THEN 3&#10;ELSEIF [total_spend] &gt;= &#10;    { FIXED : PERCENTILE([total_spend], 0.2) } THEN 2&#10;ELSE 1&#10;END' />
            </column>
            <column caption='RFM Segment' datatype='string' name='[Calculation_1756614990076665867]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [Calculation_1756614989522669571] &gt;= 4&#10;AND [Calculation_1756614990065725445] &gt;= 4&#10;AND [Calculation_1756614990065926150] &gt;= 4 THEN &quot;Champions&quot;&#10;&#10;ELSEIF [Calculation_1756614989522669571] &lt;= 2&#10;AND [Calculation_1756614990065725445] &gt;= 4&#10;AND [Calculation_1756614990065926150] &gt;= 3 THEN &quot;At Risk – High Value&quot;&#10;&#10;ELSEIF [Calculation_1756614989522669571] &gt;= 4&#10;AND [Calculation_1756614990065725445] &lt;= 2 THEN &quot;New / Promising Customers&quot;&#10;&#10;ELSEIF [Calculation_1756614989522669571] &lt;= 2&#10;AND [Calculation_1756614990065725445] &lt;= 2 THEN &quot;Lost Customers&quot;&#10;&#10;ELSE &quot;Potential Loyalists&quot;&#10;END' />
            </column>
            <column caption='City' datatype='string' name='[city]' role='dimension' semantic-role='[City].[Name]' type='nominal' />
            <column-instance column='[customer_id]' derivation='CountD' name='[ctd:customer_id:qk]' pivot='key' type='quantitative' />
            <column caption='Customer Id' datatype='string' name='[customer_id]' role='dimension' type='nominal' />
            <column caption='Is Returning Customer' datatype='boolean' name='[is_returning_customer]' role='dimension' type='nominal' />
            <column caption='Last Purchase Date' datatype='date' name='[last_purchase_date]' role='dimension' type='ordinal' />
            <column-instance column='[Calculation_1756614990076665867]' derivation='None' name='[none:Calculation_1756614990076665867:nk]' pivot='key' type='nominal' />
            <column-instance column='[city]' derivation='None' name='[none:city:nk]' pivot='key' type='nominal' />
            <column-instance column='[is_returning_customer]' derivation='None' name='[none:is_returning_customer:nk]' pivot='key' type='nominal' />
            <column-instance column='[product_category]' derivation='None' name='[none:product_category:nk]' pivot='key' type='nominal' />
            <column caption='Product Category' datatype='string' name='[product_category]' role='dimension' type='nominal' />
            <column caption='Total Orders' datatype='integer' name='[total_orders]' role='measure' type='quantitative' />
            <column caption='Total Spend' datatype='real' name='[total_spend]' role='measure' type='quantitative' />
          </datasource-dependencies>
